# flasher-service environment configuration
# Copy this file to /etc/flasher-service/flasher-service.env and edit as needed.
# All variables are optional; sensible defaults are shown below.

# -------------------------------------------------------------------------
# Network
# -------------------------------------------------------------------------

# Address to bind the HTTP server to.
FLASHER_BIND_HOST=0.0.0.0

# TCP port.
FLASHER_BIND_PORT=8080

# -------------------------------------------------------------------------
# Authentication
# -------------------------------------------------------------------------

# ****** required in the Authorization header for protected endpoints.
# Leave empty (or comment out) to disable authentication.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
#FLASHER_API_TOKEN=changeme

# -------------------------------------------------------------------------
# Target device
# -------------------------------------------------------------------------

# Explicit target block device.  Leave empty to auto-detect the eMMC device
# (recommended for unambiguous single-eMMC boards).
#FLASHER_TARGET_DEVICE=/dev/mmcblk1

# -------------------------------------------------------------------------
# Allowed image URL hosts
# -------------------------------------------------------------------------

# Comma-separated list of hostnames or CIDR subnets that are allowed as
# image URL sources.  Leave empty to allow any http/https host.
#FLASHER_ALLOWED_HOSTS=192.168.1.0/24,files.example.com

# -------------------------------------------------------------------------
# Performance
# -------------------------------------------------------------------------

# Write chunk size in bytes (default: 4 MiB).
#FLASHER_CHUNK_SIZE=4194304

# HTTP connect/read timeout in seconds.
#FLASHER_HTTP_TIMEOUT=30
